-- 1. Tốc độ giới hạn: 500
CreateToggle("Tốc Độ (Speed 500)", function(state)
    _G.SpeedHack = state
    task.spawn(function()
        while _G.SpeedHack do
            pcall(function()
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                    LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 500
                end
            end)
            task.wait(0.1)
        end
        pcall(function() LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 16 end)
    end)
end)

-- 2. Nhảy cao giới hạn: 500
CreateToggle("Nhảy Cao (Jump 500)", function(state)
    _G.JumpHack = state
    task.spawn(function()
        while _G.JumpHack do
            pcall(function()
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                    local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    if hum.UseJumpPower then
                        hum.JumpPower = 500
                    else
                        hum.JumpHeight = 500
                    end
                end
            end)
            task.wait(0.1)
        end
        pcall(function() 
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum.UseJumpPower then hum.JumpPower = 50 else hum.JumpHeight = 7.2 end
        end)
    end)
end)

-- 3. Xuyên tường (Noclip)
CreateToggle("Xuyên Tường (Noclip)", function(state)
    _G.Noclip = state
    if state then
        _G.NoclipConn = RunService.Stepped:Connect(function()
            if _G.Noclip and LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if _G.NoclipConn then _G.NoclipConn:Disconnect() end
    end
end)

-- 4. Nhìn thấy tên người khác (ESP Name)
local esp_folder = Instance.new("Folder", parentTarget)
CreateToggle("Nhìn Thấy Tên (ESP)", function(state)
    _G.ESPName = state
    if not state then
        esp_folder:ClearAllChildren()
    else
        task.spawn(function()
            while _G.ESPName do
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and not esp_folder:FindFirstChild(v.Name) then
                        local billboard = Instance.new("BillboardGui", esp_folder)
                        billboard.Name = v.Name
                        billboard.Adornee = v.Character.Head
                        billboard.Size = UIDim2.new(0, 150, 0, 40)
                        billboard.AlwaysOnTop = true
                        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
                        
                        local label = Instance.new("TextLabel", billboard)
                        label.Size = UIDim2.new(1, 0, 1, 0)
                        label.BackgroundTransparency = 1
                        label.Text = v.Name
                        label.TextColor3 = Color3.fromRGB(255, 235, 40)
                        label.TextSize = 13
                        label.Font = Enum.Font.SourceSansBold
                    end
                end
                task.wait(1)
            end
        end)
    end
end)

-- 5. Bay (Fly tối ưu hóa cho Joystick Điện Thoại)
local FlyBodyGyro, FlyBodyVelocity
CreateToggle("Bay (Fly Mobile)", function(state)
    _G.FlyMobile = state
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    if state then
        local pPart = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")
        
        FlyBodyGyro = Instance.new("BodyGyro", pPart)
        FlyBodyGyro.P = 9e4
        FlyBodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        FlyBodyGyro.cframe = pPart.CFrame
        
        FlyBodyVelocity = Instance.new("BodyVelocity", pPart)
        FlyBodyVelocity.velocity = Vector3.new(0, 0.1, 0)
        FlyBodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
        
        task.spawn(function()
            while _G.FlyMobile and char and hum and pPart do
                hum.PlatformStand = true
                -- Nhận tín hiệu di chuyển từ Joystick của điện thoại
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude > 0 then
                    -- Bay theo hướng camera điện thoại đang nhìn và Joystick đang gạt
                    FlyBodyVelocity.velocity = moveDir * 70 -- Tốc độ bay (Có thể chỉnh số 70 cao hơn)
                else
                    FlyBodyVelocity.velocity = Vector3.new(0, 0.1, 0) -- Đứng yên trên không
                end
                FlyBodyGyro.cframe = workspace.CurrentCamera.CFrame
                task.wait()
            end
            -- Khôi phục lại khi tắt trạng thái bay
            if FlyBodyGyro then FlyBodyGyro:Destroy() end
            if FlyBodyVelocity then FlyBodyVelocity:Destroy() end
            if hum then hum.PlatformStand = false end
        end)
    else
        if FlyBodyGyro then FlyBodyGyro:Destroy() end
        if FlyBodyVelocity then FlyBodyVelocity:Destroy() end
        if char:FindFirstChildOfClass("Humanoid") then
            char:FindFirstChildOfClass("Humanoid").PlatformStand = false
        end
    end
end)
             
